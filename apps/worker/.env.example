# Local Worker environment template
#
# Copy this file to .env when you need a human-readable local config reference.
# Wrangler local development still uses values from wrangler.toml and secrets from
# Wrangler / Cloudflare. Keep this file in sync with src/core/config.ts.

# Application identity
APP_NAME=WeMail
ENVIRONMENT=local

# Session / cookie
COOKIE_NAME=wemail_session
COOKIE_SECURE=false
SESSION_TTL_HOURS=72

# Mailbox
DEFAULT_MAIL_DOMAIN=example.com
MAILBOX_LIMIT=5
MESSAGE_RETENTION_DAYS=7

# Outbound / AI / attachments
OUTBOUND_DAILY_LIMIT=20
AI_FALLBACK_LIMIT=20
MAX_ATTACHMENT_BYTES=10485760
MAX_TOTAL_ATTACHMENT_BYTES=15728640

# Feature flags
ENABLE_AI=true
ENABLE_TELEGRAM=true
ENABLE_OUTBOUND=true
ENABLE_MAILBOX_CREATION=true

# Admin bootstrap emails, comma-separated
ADMIN_EMAILS=admin@example.com

# Optional integration values for local reference only.
# Real Worker secrets should be managed with Wrangler secret put.
RESEND_FROM=
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
